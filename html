    if (page === 'overview') {
      // 服务量构成
      const pie1 = echarts.init(document.getElementById('chart-service-pie'));
      pie1.setOption({
        backgroundColor: darkBg,
        tooltip: { trigger: 'item', formatter: '{b}: {c} ({d}%)' },
        legend: { bottom: 0, textStyle: { color: textColor }, itemWidth: 10, itemHeight: 10 },
        series: [{
          type: 'pie', radius: ['40%','68%'], center: ['50%','45%'],
